<?xml version="1.0" ?>
<sdf version="1.9">
  <world name="agentic_racer_track">
    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="gz-sim-contact-system" name="gz::sim::systems::Contact"/>

    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation><range>1000</range><constant>0.9</constant><linear>0.01</linear><quadratic>0.001</quadratic></attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><plane><normal>0 0 1</normal><size>200 200</size></plane></geometry>
        </collision>
        <visual name="visual">
          <geometry><plane><normal>0 0 1</normal><size>200 200</size></plane></geometry>
          <material><ambient>0.8 0.8 0.8 1</ambient><diffuse>0.8 0.8 0.8 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="track">
      <static>true</static>
      <!-- Edge 0 -->
      <link name="outer_0">
        <pose>8.366 4.83 0.25 0 0 2.0944</pose>
        <collision name="col"><geometry><box><size>10.5 0.2 0.5</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>10.5 0.2 0.5</size></box></geometry><material><ambient>1 0 0 1</ambient></material></visual>
      </link>
      <link name="inner_0">
        <pose>6.634 3.83 0.25 0 0 2.0944</pose>
        <collision name="col"><geometry><box><size>10.5 0.2 0.5</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>10.5 0.2 0.5</size></box></geometry><material><ambient>0 0 1 1</ambient></material></visual>
      </link>
      <!-- Edge 1 -->
      <link name="outer_1">
        <pose>0 9.66 0.25 0 0 3.1415</pose>
        <collision name="col"><geometry><box><size>10.5 0.2 0.5</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>10.5 0.2 0.5</size></box></geometry><material><ambient>1 0 0 1</ambient></material></visual>
      </link>
      <link name="inner_1">
        <pose>0 7.66 0.25 0 0 3.1415</pose>
        <collision name="col"><geometry><box><size>10.5 0.2 0.5</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>10.5 0.2 0.5</size></box></geometry><material><ambient>0 0 1 1</ambient></material></visual>
      </link>
      <!-- Edge 2 -->
      <link name="outer_2">
        <pose>-8.366 4.83 0.25 0 0 -2.0944</pose>
        <collision name="col"><geometry><box><size>10.5 0.2 0.5</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>10.5 0.2 0.5</size></box></geometry><material><ambient>1 0 0 1</ambient></material></visual>
      </link>
      <link name="inner_2">
        <pose>-6.634 3.83 0.25 0 0 -2.0944</pose>
        <collision name="col"><geometry><box><size>10.5 0.2 0.5</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>10.5 0.2 0.5</size></box></geometry><material><ambient>0 0 1 1</ambient></material></visual>
      </link>
      <!-- Edge 3 -->
      <link name="outer_3">
        <pose>-8.366 -4.83 0.25 0 0 -1.0472</pose>
        <collision name="col"><geometry><box><size>10.5 0.2 0.5</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>10.5 0.2 0.5</size></box></geometry><material><ambient>1 0 0 1</ambient></material></visual>
      </link>
      <link name="inner_3">
        <pose>-6.634 -3.83 0.25 0 0 -1.0472</pose>
        <collision name="col"><geometry><box><size>10.5 0.2 0.5</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>10.5 0.2 0.5</size></box></geometry><material><ambient>0 0 1 1</ambient></material></visual>
      </link>
      <!-- Edge 4 -->
      <link name="outer_4">
        <pose>0 -9.66 0.25 0 0 0</pose>
        <collision name="col"><geometry><box><size>10.5 0.2 0.5</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>10.5 0.2 0.5</size></box></geometry><material><ambient>1 0 0 1</ambient></material></visual>
      </link>
      <link name="inner_4">
        <pose>0 -7.66 0.25 0 0 0</pose>
        <collision name="col"><geometry><box><size>10.5 0.2 0.5</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>10.5 0.2 0.5</size></box></geometry><material><ambient>0 0 1 1</ambient></material></visual>
      </link>
      <!-- Edge 5 -->
      <link name="outer_5">
        <pose>8.366 -4.83 0.25 0 0 1.0472</pose>
        <collision name="col"><geometry><box><size>10.5 0.2 0.5</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>10.5 0.2 0.5</size></box></geometry><material><ambient>1 0 0 1</ambient></material></visual>
      </link>
      <link name="inner_5">
        <pose>6.634 -3.83 0.25 0 0 1.0472</pose>
        <collision name="col"><geometry><box><size>10.5 0.2 0.5</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>10.5 0.2 0.5</size></box></geometry><material><ambient>0 0 1 1</ambient></material></visual>
      </link>
    </model>
  </world>
</sdf>
