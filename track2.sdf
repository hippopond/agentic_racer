      <link name="inner_4"><pose>-8.0 -3.32 0.25 0 0 -1.1781</pose><collision name="col"><geometry><box><size>8.5 0.2 0.5</size></box></geometry></collision><visual name="vis"><geometry><box><size>8.5 0.2 0.5</size></box></geometry><material><ambient>0 0 1 1</ambient></material></visual></link>
      <!-- Edge 5 -->
